#!/bin/bash
# Launch Ulauncher and immediately pin its window to all workspaces.
# Without this, GNOME remembers the window on workspace 1 and switches
# back there every time you trigger the hotkey from another workspace.
env GDK_BACKEND=x11 /usr/bin/ulauncher --hide-window &

for i in $(seq 20); do
    sleep 0.5
    WID=$(xdotool search --classname "ulauncher" 2>/dev/null | head -1)
    if [ -n "$WID" ]; then
        # wmctrl only works on visible windows; xprop sets the property directly
        # on the hidden window so GNOME honors it when the window is shown.
        xprop -id "$WID" -f _NET_WM_STATE 32a -set _NET_WM_STATE "_NET_WM_STATE_STICKY"
        xprop -id "$WID" -f _NET_WM_DESKTOP 32c -set _NET_WM_DESKTOP 4294967295
        break
    fi
done
