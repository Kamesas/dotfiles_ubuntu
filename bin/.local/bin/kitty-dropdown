#!/bin/bash
# Toggle the kitty dropdown.
# On Sway: native Wayland window, shown/hidden via swaymsg + scratchpad.
# On GNOME: runs under XWayland so xdotool can show/hide without restarting.

WM_CLASS="kitty-dropdown"

if [ -n "$SWAYSOCK" ]; then
    # Only one dropdown on screen at a time — hide the other one first.
    swaymsg '[class="wezterm-dropdown"] move scratchpad' > /dev/null 2>&1
    if ! pgrep -f "kitty.*dropdown.conf" > /dev/null; then
        kitty --config ~/.config/kitty/dropdown.conf --class "$WM_CLASS" &
    else
        swaymsg "[app_id=\"$WM_CLASS\"] scratchpad show" > /dev/null
    fi
    exit 0
fi

if ! pgrep -f "kitty.*dropdown.conf" > /dev/null; then
    WAYLAND_DISPLAY= DISPLAY=:0 kitty --config ~/.config/kitty/dropdown.conf --class "$WM_CLASS" &
    WID=$(xdotool search --sync --onlyvisible --classname "$WM_CLASS")
    sleep 0.3
    xdotool windowmove "$WID" 0 64
    xdotool windowsize "$WID" 3072 1664
    exit 0
fi

# wmctrl reads mutter's own window list instead of walking the whole X11
# tree, which under GNOME/XWayland holds thousands of unmanaged helper
# windows and makes `xdotool search` take over a second.
WID_HEX=$(wmctrl -lx 2>/dev/null | grep -F "$WM_CLASS" | head -1 | awk '{print $1}')
[ -z "$WID_HEX" ] && exit 0
WID=$((WID_HEX))

ACTIVE=$(xdotool getactivewindow 2>/dev/null)

if [ "$WID" = "$ACTIVE" ]; then
    xdotool windowminimize "$WID"
else
    sleep 0.1
    xdotool windowactivate --sync "$WID"
    xdotool windowraise "$WID"
    xdotool windowfocus --sync "$WID"
fi
