#!/bin/bash
# Toggle the WezTerm dropdown.
# Runs under XWayland so xdotool can show/hide the window without restarting.

CONFIG="$HOME/.config/wezterm/dropdown.lua"
WM_CLASS="org.wezfurlong.wezterm"

# Start WezTerm under XWayland if not already running
if ! pgrep -f "wezterm.*dropdown.lua" > /dev/null; then
    WAYLAND_DISPLAY= DISPLAY=:0 wezterm --config-file "$CONFIG" &
    exit 0
fi

WID=$(xdotool search --classname "$WM_CLASS" 2>/dev/null | head -1)
[ -z "$WID" ] && exit 0

ACTIVE=$(xdotool getactivewindow 2>/dev/null)

if [ "$WID" = "$ACTIVE" ]; then
    xdotool windowminimize "$WID"
else
    xdotool set_desktop_for_window "$WID" $(xdotool get_desktop)
    xdotool windowactivate --sync "$WID"
    xdotool windowraise "$WID"
fi
