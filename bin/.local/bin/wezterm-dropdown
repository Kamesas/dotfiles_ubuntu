#!/bin/bash
# Toggle the WezTerm dropdown.
# Always runs under XWayland — the installed wezterm (20240203, latest in the Arch
# repo) crashes on native Sway Wayland windows with a wl_shm protocol error.
# On Sway: shown/hidden via swaymsg + scratchpad (XWayland windows match by "class").
# On GNOME: xdotool shows/hides it without restarting.

CONFIG="$HOME/.config/wezterm/dropdown.lua"
WM_CLASS="wezterm-dropdown"

# "scratchpad show" toggles, but it shows the window back at its old
# output/position, not the currently focused one. "move container to output
# current" fixes the output (and un-hides it as a side effect), so visibility
# has to be checked first to still get a real show/hide toggle.
is_dropdown_visible() {
    swaymsg -t get_tree | python3 -c "
import json, sys
data = json.load(sys.stdin)
def walk(n):
    if n.get('window_properties', {}).get('class') == '$WM_CLASS':
        sys.exit(0 if n.get('visible') else 1)
    for c in n.get('nodes', []) + n.get('floating_nodes', []):
        walk(c)
walk(data)
sys.exit(1)
"
}

if [ -n "$SWAYSOCK" ]; then
    # Only one dropdown on screen at a time — hide the other one first.
    swaymsg '[app_id="kitty-dropdown"] move scratchpad' > /dev/null 2>&1
    if ! pgrep -f "wezterm.*dropdown.lua" > /dev/null; then
        WAYLAND_DISPLAY= DISPLAY=:0 wezterm --config-file "$CONFIG" start --class "$WM_CLASS" &
    elif is_dropdown_visible; then
        swaymsg "[class=\"$WM_CLASS\"] move scratchpad" > /dev/null
    else
        swaymsg "[class=\"$WM_CLASS\"] move container to output current, resize set width 100 ppt height 100 ppt, move position 0 ppt 0 ppt, focus" > /dev/null
    fi
    exit 0
fi

# Start WezTerm under XWayland if not already running
if ! pgrep -f "wezterm.*dropdown.lua" > /dev/null; then
    WAYLAND_DISPLAY= DISPLAY=:0 wezterm --config-file "$CONFIG" start --class "$WM_CLASS" &
    exit 0
fi

# wmctrl reads mutter's own window list instead of walking the whole X11
# tree, which under GNOME/XWayland holds thousands of unmanaged helper
# windows and makes `xdotool search` take over a second.
WID_HEX=$(wmctrl -lx 2>/dev/null | grep -F "$WM_CLASS" | head -1 | awk '{print $1}')
[ -z "$WID_HEX" ] && exit 0
WID=$((WID_HEX))

ACTIVE=$(xdotool getactivewindow 2>/dev/null)

if [ "$WID" = "$ACTIVE" ]; then
    xdotool windowminimize "$WID"
else
    xdotool windowactivate --sync "$WID"
    xdotool windowraise "$WID"
fi
