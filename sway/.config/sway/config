# Sway config — T480
# Mod = Super (Win) key
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

set $term kitty
set $menu rofi -show drun

### Catppuccin Mocha colors
set $base   #1e1e2e
set $mantle #181825
set $text   #cdd6f4
set $blue   #89b4fa
set $blue_dim #546994
set $surface1 #45475a
set $red    #f38ba8

# Window colors:        border    background  text    indicator  child_border
client.focused          $blue_dim $base       $text   $blue_dim  $blue_dim
client.unfocused        $surface1 $base       $text   $surface1  $surface1
client.focused_inactive $surface1 $base       $text   $surface1  $surface1
client.urgent           $red      $base       $text   $red       $red

default_border pixel 2
default_floating_border pixel 2
gaps inner 6
gaps outer 3

### Input
input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
    middle_emulation enabled
}

input type:keyboard {
    xkb_layout us,ua
}

### Output layout — external stacked above the laptop, laptop centered below.
# 320 = (2560 - 1920) / 2, so the narrower laptop sits centred under the wider
# external and the cursor crosses cleanly in the middle. External matched by
# make/model/serial so it survives different HDMI/DP ports.
output "Lenovo Group Limited R27qe UP3359FZ" position 0 0
output eDP-1 position 320 1440

### Autostart
exec wl-paste --watch cliphist store
exec blueman-applet
exec mako
exec /usr/lib/mate-polkit/polkit-mate-authentication-agent-1
exec awww-daemon
exec swayidle -w timeout 1200 ~/.local/bin/idle-suspend-on-battery
exec ~/.local/bin/display-guard

### Keybindings — basics
bindsym $mod+Return exec $term
bindsym $mod+c kill
bindsym --whole-window $mod+button2 kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes' 'swaymsg exit'
bindsym $mod+Shift+p exec wlogout
floating_modifier $mod normal

### Keybindings — custom (matches GNOME setup)
bindsym Alt+t exec ~/.local/bin/kitty-dropdown
bindsym Alt+w exec ~/.local/bin/wezterm-dropdown
bindsym Alt+u exec rofi -show drun
bindsym Alt+f exec rofi -show window
bindsym Alt+n exec ~/.local/bin/wifi-menu
bindsym Alt+m exec ~/.local/bin/mic-menu
bindsym Alt+a exec ~/.local/bin/sink-menu
bindsym Alt+s exec ~/.local/bin/display-menu
bindsym Alt+d exec makoctl mode -t do-not-disturb && pkill -SIGRTMIN+8 waybar
bindsym Alt+p exec ~/.local/bin/clipboard-menu
bindsym Alt+o exec ~/.local/bin/wallpaper-menu
bindsym Alt+y exec ~/.local/bin/waybar-toggle
bindsym Print exec grim -g "$(slurp)" - | swappy -f -

### Keybindings — focus
bindsym $mod+Shift+h focus left
bindsym $mod+Shift+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym Alt+h focus left
bindsym Alt+j focus down
bindsym Alt+k focus up
bindsym Alt+l focus right

### Keybindings — move window within workspace
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### Keybindings — switch workspace (vim-style: h = prev, l = next)
# ws-relative steps by number and creates the next workspace on demand, so "next"
# past the last one opens a fresh one instead of wrapping (like GNOME).
bindsym $mod+h exec ~/.local/bin/ws-relative prev
bindsym $mod+l exec ~/.local/bin/ws-relative next

### Keybindings — move window to adjacent workspace and follow
bindsym $mod+j exec ~/.local/bin/ws-relative next move
bindsym $mod+k exec ~/.local/bin/ws-relative prev move

### Workspace-to-output assignment
# Pin number ranges to each monitor so numbering stays fixed instead of sharing
# one global pool: external 1–5, laptop 6–10. The external is matched by
# make/model/serial, so it keeps its range across different HDMI/DP ports.
# When the external is unplugged, all workspaces fall back to the laptop.
workspace 1 output "Lenovo Group Limited R27qe UP3359FZ"
workspace 2 output "Lenovo Group Limited R27qe UP3359FZ"
workspace 3 output "Lenovo Group Limited R27qe UP3359FZ"
workspace 4 output "Lenovo Group Limited R27qe UP3359FZ"
workspace 5 output "Lenovo Group Limited R27qe UP3359FZ"
workspace 6 output eDP-1
workspace 7 output eDP-1
workspace 8 output eDP-1
workspace 9 output eDP-1
workspace 10 output eDP-1

### Keybindings — workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym Ctrl+Alt+1 move container to workspace number 1
bindsym Ctrl+Alt+2 move container to workspace number 2
bindsym Ctrl+Alt+3 move container to workspace number 3
bindsym Ctrl+Alt+4 move container to workspace number 4
bindsym Ctrl+Alt+5 move container to workspace number 5
bindsym Ctrl+Alt+6 move container to workspace number 6
bindsym Ctrl+Alt+7 move container to workspace number 7
bindsym Ctrl+Alt+8 move container to workspace number 8
bindsym Ctrl+Alt+9 move container to workspace number 9
bindsym Ctrl+Alt+0 move container to workspace number 10

### Keybindings — layout
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+a focus parent

### Keybindings — keyboard layout (matches GNOME's Win+Space)
bindsym $mod+space input "*" xkb_switch_layout next

### Keybindings — scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

### Keybindings — resize mode
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### Media / brightness keys
bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle && pkill -SIGRTMIN+9 waybar
bindsym --locked XF86MonBrightnessDown exec ~/.local/bin/brightness-osd 5%-
bindsym --locked XF86MonBrightnessUp exec ~/.local/bin/brightness-osd 5%+

### Status bar
bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*

for_window [app_id=".*"] border pixel 2
for_window [class=".*"] border pixel 2

### Dropdown terminals — float, fill the workspace area (Waybar stays visible),
# and park in the scratchpad so Alt+t / Alt+w show/hide them from any workspace.
for_window [app_id="kitty-dropdown"] floating enable, resize set width 100 ppt height 100 ppt, move position 0 ppt 0 ppt, move scratchpad, scratchpad show
# WezTerm dropdown runs under XWayland (see wezterm-dropdown script), so it shows
# up as an X11 "class" rather than a native Wayland "app_id".
for_window [class="wezterm-dropdown"] floating enable, resize set width 100 ppt height 100 ppt, move position 0 ppt 0 ppt, move scratchpad, scratchpad show
