{
  // ═══════════════════════════════════════════════════════════════════════════
  // EDITOR - Font & Appearance
  // ═══════════════════════════════════════════════════════════════════════════
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 17,
  "editor.fontWeight": "500",
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.wordWrapColumn": 100,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.linkedEditing": true,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.maxTokenizationLineLength": 9e26,
  "editor.cursorBlinking": "solid",
  // ═══════════════════════════════════════════════════════════════════════════
  // EDITOR - Behavior
  // ═══════════════════════════════════════════════════════════════════════════
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.suggest.insertMode": "replace",
  "editor.suggest.matchOnWordStartOnly": false,
  "editor.suggest.showStatusBar": true,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.addMissingImports.ts": "always",
    "source.organizeImports": "always",
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // WORKBENCH - Theme & UI
  // ═══════════════════════════════════════════════════════════════════════════
  "workbench.colorTheme": "Default Dark+",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorCustomizations": {},
  "workbench.startupEditor": "none",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.customLabels.patterns": {
    "**/{layout,page}.tsx": "${dirname} ${filename}",
  },
  "workbench.tree.enableStickyScroll": false,
  "workbench.experimental.share.enabled": true,
  "window.zoomLevel": 1.45,
  "explorer.compactFolders": false,

  // ═══════════════════════════════════════════════════════════════════════════
  // ZEN MODE
  // ═══════════════════════════════════════════════════════════════════════════
  "zenMode.hideLineNumbers": false,
  "zenMode.hideActivityBar": false,

  // ═══════════════════════════════════════════════════════════════════════════
  // TERMINAL
  // ═══════════════════════════════════════════════════════════════════════════
  "terminal.integrated.fontFamily": "FiraCode Nerd Font",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.profiles.linux": {
    "bash": { "path": "/usr/bin/bash", "icon": "terminal-bash" },
    "fish": { "path": "/usr/bin/fish" },
    "tmux": { "path": "/usr/bin/tmux", "icon": "terminal-tmux" },
  },
  "terminal.integrated.profiles.windows": {
    "Moddable ESP32": {
      "path": "cmd.exe",
      "args": ["/k", "F:\\Coding\\esp_32\\moddable_env.bat"],
      "icon": "chip",
    },
  },
  "terminal.integrated.env.windows": {},

  // ═══════════════════════════════════════════════════════════════════════════
  // NEOVIM
  // ═══════════════════════════════════════════════════════════════════════════
  "vscode-neovim.neovimExecutablePaths.linux": "/home/alex/.local/bin/vscode-neovim/nvim",
  "vscode-neovim.neovimInitVimPaths.linux": "/home/alex/.config/nvim-vscode/init.lua",
  "vscode-neovim.compositeKeys": {
    "jk": {
      "command": "vscode-neovim.escape",
    },
  },
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // GIT
  // ═══════════════════════════════════════════════════════════════════════════
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.suggestSmartCommit": false,
  "gitlens.views.commitDetails.files.layout": "tree",

  // ═══════════════════════════════════════════════════════════════════════════
  // DIFF EDITOR
  // ═══════════════════════════════════════════════════════════════════════════
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.maxComputationTime": 0,
  "diffEditor.codeLens": true,

  // ═══════════════════════════════════════════════════════════════════════════
  // JAVASCRIPT / TYPESCRIPT
  // ═══════════════════════════════════════════════════════════════════════════
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "non-relative",

  // ═══════════════════════════════════════════════════════════════════════════
  // LANGUAGE-SPECIFIC FORMATTERS
  // ═══════════════════════════════════════════════════════════════════════════
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
  },
  "[sql]": {
    "editor.defaultFormatter": "mtxr.sqltools",
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // ESLINT
  // ═══════════════════════════════════════════════════════════════════════════
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "vue",
    "markdown",
    "css",
    "scss",
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // EMMET
  // ═══════════════════════════════════════════════════════════════════════════
  "emmet.triggerExpansionOnTab": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // BETTER COMMENTS
  // ═══════════════════════════════════════════════════════════════════════════
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "FIXME",
      "color": "red",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false,
    },
    {
      "tag": "TODO",
      "color": "green",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false,
    },
    {
      "tag": "info",
      "color": "orange",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false,
    },
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // SQLTOOLS
  // ═══════════════════════════════════════════════════════════════════════════
  "sqltools.results.reuseTabs": "connection",

  // ═══════════════════════════════════════════════════════════════════════════
  // CSPELL - Custom Words
  // ═══════════════════════════════════════════════════════════════════════════
  "cSpell.userWords": [
    "chartjs",
    "chegg",
    "Contentful",
    "craco",
    "daisyui",
    "esnext",
    "ETQB",
    "gmail",
    "heroicons",
    "kysely",
    "Phonendoscope",
    "scrollbar",
    "Slava",
    "submenu",
    "testid",
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // OTHER EXTENSIONS
  // ═══════════════════════════════════════════════════════════════════════════
  "code-runner.runInTerminal": true,
  "codeium.enableConfig": {
    "*": true,
    "ignore": true,
    "properties": true,
  },
  "docker.extension.enableComposeLanguageServer": false,
  "yaml.schemas": {
    "file:///home/alex/.vscode/extensions/continue.continue-1.0.23-linux-x64/config-yaml-schema.json": [
      ".continue/**/*.yaml",
    ],
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // CHAT / AI
  // ═══════════════════════════════════════════════════════════════════════════
  "chat.editor.fontSize": 15,
  "chat.commandCenter.enabled": false,
  "chat.mcp.serverSampling": {
    "Global in Code: huggingface": {
      "allowedModels": [],
    },
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // MISC
  // ═══════════════════════════════════════════════════════════════════════════
  "json.maxItemsComputed": 11000,
  "security.workspace.trust.untrustedFiles": "open",
  "settingsSync.ignoredExtensions": ["pkief.material-icon-theme"],
  "remote.autoForwardPortsSource": "hybrid",
  "redhat.telemetry.enabled": true,
}
