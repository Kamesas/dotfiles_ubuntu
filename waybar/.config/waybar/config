{
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 4,
    "ipc": true,

    "modules-left": ["sway/workspaces", "custom/wezterm-dropdown", "custom/kitty-dropdown", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "custom/mic", "pulseaudio", "network", "sway/language", "battery", "custom/notifications", "tray", "custom/power"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "sway/window": {
        "max-length": 60
    },

    "clock": {
        "format": "{:%a %d %b  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><span size=\"200%\">{calendar}</span></tt>"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 2
    },

    "memory": {
        "format": " {used:0.1f}/{total:0.1f}GB",
        "interval": 5
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " {ipaddr}",
        "format-disconnected": "󰤭 off",
        "tooltip-format": "{ifname}: {ipaddr}\n{essid} ({signalStrength}%)"
    },

    "sway/language": {
        "format": "{flag} {short}",
        "tooltip-format": "{long}"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 muted",
        "format-icons": { "default": ["", "", ""] },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "custom/mic": {
        "exec": "~/.local/bin/mic-status",
        "interval": 5,
        "signal": 9,
        "return-type": "json",
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle && pkill -SIGRTMIN+9 waybar",
        "on-click-right": "~/.local/bin/mic-menu",
        "on-scroll-up": "~/.local/bin/mic-volume-osd 5%+",
        "on-scroll-down": "~/.local/bin/mic-volume-osd 5%-",
        "tooltip": true
    },

    "custom/kitty-dropdown": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "Kitty dropdown terminal (Alt+t)",
        "on-click": "~/.local/bin/kitty-dropdown"
    },

    "custom/wezterm-dropdown": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "WezTerm dropdown terminal (Alt+w)",
        "on-click": "~/.local/bin/wezterm-dropdown"
    },

    "custom/notifications": {
        "exec": "~/.local/bin/notification-indicator",
        "interval": 5,
        "signal": 8,
        "return-type": "json",
        "on-click": "makoctl dismiss --all && pkill -SIGRTMIN+8 waybar",
        "tooltip": true
    },

    "tray": {
        "spacing": 8
    },

    "custom/power": {
        "format": "",
        "on-click": "wlogout",
        "tooltip": false
    }
}
